{
  "enabled_models": ["cox_ph", "deepsurv", "rsf", "response_classifier", "attention_fusion"],
  "model_params": {
    "cox_ph": {
      "penalizer": 0.1,
      "l1_ratio": 0.0
    },
    "deepsurv": {
      "hidden_dims": [256, 128, 64],
      "dropout": 0.3,
      "weight_decay": 1e-4
    },
    "rsf": {
      "n_estimators": 100,
      "max_depth": null,
      "min_samples_leaf": 15,
      "max_features": "sqrt"
    },
    "response_classifier": {
      "model_type": "xgboost",
      "params": {
        "n_estimators": 200,
        "max_depth": 6,
        "learning_rate": 0.1,
        "subsample": 0.8,
        "colsample_bytree": 0.8
      }
    },
    "attention_fusion": {
      "hidden_dim": 128,
      "n_heads": 4,
      "dropout": 0.2,
      "task": "survival"
    }
  },
  "n_epochs": 100,
  "early_stopping_patience": 10,
  "batch_size": 64,
  "learning_rate": 1e-3
}
